# IoT backend environment - Databricks Edition

SECRET_KEY=change-this-in-production
ALGORITHM=HS256

DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=rtmps_db
DB_USERNAME=rtmps_user
DB_PASSWORD=change-me
# DATABASE_URL=postgresql+psycopg2://username:password@127.0.0.1:5432/rtmps_db

MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=sensor_user
MQTT_PASSWORD=change-me
MQTT_CLIENT_ID=iot-backend
MQTT_SENSOR_TOPIC=sensors/+/data
MQTT_COMMAND_TOPIC_PREFIX=ptdl/devices
MQTT_WIFI_LIST_TOPIC=ptdl/devices/+/wifi-list

# Kafka event streaming (optional)
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
KAFKA_CLIENT_ID=iot-backend-producer
KAFKA_SENSOR_TOPIC=iot.sensor.readings.v1
KAFKA_METRIC_TOPIC=iot.sensor.readings.v1
KAFKA_ACKS=1
KAFKA_REQUEST_TIMEOUT_MS=15000
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

DATABRICKS_ENABLED=false
DATABRICKS_DIRECT_WRITE_ENABLED=false
DATABRICKS_SERVER_HOSTNAME=
DATABRICKS_HTTP_PATH=
DATABRICKS_TOKEN=
DATABRICKS_CATALOG=iot_cloud
DATABRICKS_SCHEMA=sensor_analytics
DATABRICKS_BRONZE_TABLE=bronze_sensor_readings

TELEGRAM_BOT_TOKEN=
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

FAN_ON_TEMP=32
LAMP_ON_TEMP=25
FOG_ON_HUMIDITY=60
FOG_OFF_HUMIDITY=75
