# ============================================================================
# Databricks Configuration
# ============================================================================
# Copy this file to .env and fill in your Databricks credentials

# Preferred variables (your current Databricks setup)
DATABRICKS_HOST=dbc-c02fa590-b5ef.cloud.databricks.com
DATABRICKS_PATH=/sql/1.0/warehouses/your-warehouse-id
DATABRICKS_TOKEN=dapi1234567890abcdefghijklmnop

# Optional compatibility variables (if you already use these)
DATABRICKS_WORKSPACE_URL=https://dbc-c02fa590-b5ef.cloud.databricks.com
DATABRICKS_CATALOG=workspace
DATABRICKS_SCHEMA=metrics_app_streaming

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=sqlite:///./metrics.db

# ============================================================================
# JWT Configuration
# ============================================================================
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================================
# Realtime Source Selection
# ============================================================================
# This repository mode is Kafka-only realtime.
REALTIME_SOURCE=kafka

# Kafka settings
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TELEMETRY_TOPIC=telemetry.raw
KAFKA_INSIGHT_TOPIC=insight.events
KAFKA_GROUP_PREFIX=metricspulse-backend
KAFKA_TO_DATABRICKS_FLUSH_SECONDS=2
KAFKA_TO_DATABRICKS_MAX_BATCH=200

# MQTT settings for simulator scripts
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TOPIC_TELEMETRY=esp/telemetry
