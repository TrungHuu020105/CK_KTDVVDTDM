# ===== KAFKA Configuration =====
# Confluent Cloud hoặc Local Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=iot-sensor-data
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# ===== CORS Configuration =====
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# ===== Logging =====
LOG_SENSOR_MESSAGES=false

# ===== DATABRICKS Configuration =====
# Lấy thông tin này từ Databricks workspace
# 1. Vào Settings → Developer tools → SQL connectors
# 2. Copy Server hostname, HTTP path, Personal access token

# Databricks Server Hostname (e.g., adb-xxx.cloud.databricks.com)
DATABRICKS_SERVER_HOSTNAME=

# Databricks HTTP Path (e.g., /sql/1.0/warehouses/xxx)
DATABRICKS_HTTP_PATH=

# Databricks Personal Access Token
DATABRICKS_TOKEN=

# Databricks Catalog & Table
DATABRICKS_CATALOG=iot_analytics
DATABRICKS_TABLE=smart_filtered_measurements
